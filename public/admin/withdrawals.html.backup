<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>提现审核 - FOOTRADAPRO 后台</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="/js/core/config.js"></script>
    <script src="/js/core/time.js"></script>
    <script src="/js/admin/admin_auth_guard.js"></script>
    <link rel="stylesheet" href="/css/admin-users.css">
    <style>
        /* 提现审核页面特有样式 - 基于 admin-users.css 扩展 */
        
        /* 统计卡片保持与用户管理一致 */
        .stat-card {
            background: rgba(20, 25, 35, 0.8);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 20px 24px;
            border: 1px solid rgba(255, 107, 0, 0.15);
            transition: all 0.2s;
            text-align: center;
        }
        
        /* 状态标签扩展 */
        .status-badge.status-pending {
            background: rgba(245, 158, 11, 0.2);
            color: #f59e0b;
        }
        
        .status-badge.status-approved {
            background: rgba(16, 185, 129, 0.2);
            color: #10b981;
        }
        
        .status-badge.status-rejected {
            background: rgba(239, 68, 68, 0.2);
            color: #ef4444;
        }
        
        /* 地址截断样式 */
        .address-truncate {
            max-width: 150px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            display: inline-block;
            font-family: monospace;
        }
        
        /* 筛选栏中的标签组 */
        .filter-group {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .filter-group label {
            font-size: 13px;
            color: #8e95a3;
        }
        
        /* 刷新按钮样式与 btn-secondary 保持一致 */
        .btn-refresh {
            padding: 8px 18px;
            background: rgba(0, 0, 0, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            color: #fff;
            cursor: pointer;
            font-size: 13px;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }
        
        .btn-refresh:hover {
            border-color: #ff6b00;
            color: #ff6b00;
        }
        
        /* 审核弹窗内的按钮 */
        .btn-approve {
            flex: 1;
            padding: 10px;
            background: linear-gradient(135deg, #10b981, #059669);
            border: none;
            border-radius: 8px;
            color: white;
            font-weight: 600;
            cursor: pointer;
            font-size: 13px;
            transition: all 0.2s;
        }
        
        .btn-approve:hover {
            transform: translateY(-1px);
            box-shadow: 0 2px 8px rgba(16, 185, 129, 0.4);
        }
        
        .btn-reject {
            flex: 1;
            padding: 10px;
            background: linear-gradient(135deg, #ef4444, #dc2626);
            border: none;
            border-radius: 8px;
            color: white;
            font-weight: 600;
            cursor: pointer;
            font-size: 13px;
            transition: all 0.2s;
        }
        
        .btn-reject:hover {
            transform: translateY(-1px);
            box-shadow: 0 2px 8px rgba(239, 68, 68, 0.4);
        }
        
        /* 模态框内表单样式 */
        .detail-row {
            margin-bottom: 12px;
            display: flex;
        }
        
        .detail-row label {
            width: 90px;
            font-size: 13px;
            color: #8e95a3;
        }
        
        .detail-row span {
            flex: 1;
            font-size: 14px;
            font-weight: 500;
            color: #fff;
            word-break: break-all;
        }
        
        .form-group {
            margin-bottom: 16px;
        }
        
        .form-group label {
            display: block;
            font-size: 13px;
            color: #8e95a3;
            margin-bottom: 6px;
        }
        
        .form-control {
            width: 100%;
            padding: 10px 12px;
            background: rgba(0, 0, 0, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 8px;
            color: #fff;
            font-size: 13px;
        }
        
        .form-control:focus {
            outline: none;
            border-color: #ff6b00;
        }
        
        .tx-hash-input {
            font-family: monospace;
        }
        
        .action-buttons {
            display: flex;
            gap: 12px;
            margin-top: 20px;
        }
        
        /* 通知条 */
        .notification-bar {
            background: linear-gradient(135deg, #ff6b00, #ff8a3c);
            color: #000;
            padding: 12px 20px;
            border-radius: 12px;
            margin-bottom: 20px;
            display: none;
            align-items: center;
            gap: 12px;
            font-weight: 600;
        }
        
        .notification-bar .close-btn {
            background: none;
            border: none;
            color: #000;
            cursor: pointer;
            font-size: 16px;
            margin-left: auto;
        }
        
        /* 响应式 */
        @media (max-width: 768px) {
            .detail-row {
                flex-direction: column;
            }
            .detail-row label {
                width: 100%;
                margin-bottom: 4px;
            }
            .action-buttons {
                flex-direction: column;
            }
        }
    </style>
</head>
<body>
    <div class="admin-layout">
        <!-- 侧边导航栏 -->
        <aside class="admin-sidebar">
            <div class="admin-sidebar-logo">FOOT<span>RADA</span></div>
            <nav class="admin-nav">
                <a href="/admin/dashboard.html" class="admin-nav-item"><i class="fas fa-tachometer-alt"></i> <span>仪表盘</span></a>
                <a href="/admin/stats.html" class="admin-nav-item"><i class="fas fa-chart-pie"></i> <span>数据统计</span></a>
                <a href="/admin/users.html" class="admin-nav-item"><i class="fas fa-users"></i> <span>用户管理</span></a>
                <a href="/admin/admins.html" class="admin-nav-item"><i class="fas fa-user-shield"></i> <span>管理员管理</span></a>
                <a href="/admin/deposits.html" class="admin-nav-item"><i class="fas fa-arrow-down"></i> <span>充值审核</span></a>
                <a href="/admin/withdrawals.html" class="admin-nav-item active"><i class="fas fa-arrow-up"></i> <span>提现审核</span></a>
                <a href="/admin/finance.html" class="admin-nav-item"><i class="fas fa-chart-line"></i> <span>财务管理</span></a>
                <a href="/admin/matches.html" class="admin-nav-item"><i class="fas fa-futbol"></i> <span>比赛管理</span></a>
                <a href="/admin/settle.html" class="admin-nav-item"><i class="fas fa-calculator"></i> <span>清算管理</span></a>
                <a href="/admin/report-editor.html" class="admin-nav-item"><i class="fas fa-edit"></i> <span>报告编辑</span></a>
                <a href="/admin/ticker-manager.html" class="admin-nav-item"><i class="fas fa-bolt"></i> <span>动态管理</span></a>
                <a href="/admin/notifications.html" class="admin-nav-item"><i class="fas fa-bell"></i> <span>通知管理</span></a>
                <a href="/admin/settings/index.html" class="admin-nav-item"><i class="fas fa-cog"></i> <span>系统设置</span></a>
            </nav>
        </aside>

        <!-- 主内容 -->
        <main class="admin-main">
            <header class="admin-header">
                <h1><i class="fas fa-arrow-up"></i> 提现审核</h1>
                <div class="admin-user">
                    <span id="adminName">管理员</span>
                    <button class="icon-btn" id="logoutBtn"><i class="fas fa-sign-out-alt"></i></button>
                </div>
            </header>

            <div class="admin-content">
                <!-- 通知条 -->
                <div class="notification-bar" id="notificationBar">
                    <i class="fas fa-bell"></i>
                    <span id="notificationMessage">有新的提现申请</span>
                    <button onclick="location.href='#pending'">查看</button>
                    <button class="close-btn" onclick="document.getElementById('notificationBar').style.display='none'"><i class="fas fa-times"></i></button>
                </div>

                <!-- 统计卡片 -->
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-value" id="pendingCount">0</div>
                        <div class="stat-label">待审核</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value" id="approvedCount">0</div>
                        <div class="stat-label">已通过</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value" id="rejectedCount">0</div>
                        <div class="stat-label">已驳回</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value" id="pendingAmount">0 USDT</div>
                        <div class="stat-label">待审核总额</div>
                    </div>
                </div>

                <!-- 筛选栏 -->
                <div class="filters-bar">
                    <div class="filter-group">
                        <label>状态</label>
                        <select id="statusFilter" class="filter-select">
                            <option value="pending">待审核</option>
                            <option value="approved">已通过</option>
                            <option value="rejected">已驳回</option>
                            <option value="all">全部</option>
                        </select>
                    </div>
                    <div class="search-box">
                        <i class="fas fa-search"></i>
                        <input type="text" id="searchInput" placeholder="搜索用户、UID、地址...">
                    </div>
                    <button class="btn-refresh" onclick="loadWithdrawals()">
                        <i class="fas fa-sync-alt"></i> 刷新
                    </button>
                </div>

                <!-- 提现列表表格 -->
                <div class="table-container">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>时间</th>
                                <th>用户</th>
                                <th>金额</th>
                                <th>手续费</th>
                                <th>到账</th>
                                <th>网络</th>
                                <th>提现地址</th>
                                <th>状态</th>
                                <th>操作</th>
                            </thead>
                        <tbody id="withdrawalTableBody">
                            <tr><td colspan="10" class="loading"><i class="fas fa-spinner fa-pulse"></i> 加载中...</td></tr>
                        </tbody>
                    </table>
                </div>

                <!-- 分页控件（预留） -->
                <div class="pagination" id="pagination"></div>
            </div>
        </main>
    </div>

    <!-- 审核弹窗 -->
    <div class="modal-overlay" id="reviewModal">
        <div class="modal">
            <div class="modal-header">
                <h2><i class="fas fa-gavel"></i> 审核提现</h2>
                <button class="modal-close" id="closeReviewModalBtn">&times;</button>
            </div>
            <div class="modal-body" id="reviewModalBody">
                <input type="hidden" id="reviewId">
                
                <div class="detail-row">
                    <label>用户信息</label>
                    <span id="reviewUser"></span>
                </div>
                <div class="detail-row">
                    <label>提现金额</label>
                    <span id="reviewAmount"></span>
                </div>
                <div class="detail-row">
                    <label>手续费</label>
                    <span>1 USDT</span>
                </div>
                <div class="detail-row">
                    <label>实际到账</label>
                    <span id="reviewNetAmount"></span>
                </div>
                <div class="detail-row">
                    <label>网络</label>
                    <span id="reviewNetwork"></span>
                </div>
                <div class="detail-row">
                    <label>提现地址</label>
                    <span id="reviewAddress" style="word-break: break-all;"></span>
                </div>
                <div class="detail-row">
                    <label>用户余额</label>
                    <span id="reviewBalance"></span>
                </div>

                <!-- 通过操作区 -->
                <div id="approveSection">
                    <div class="form-group">
                        <label>交易哈希 (TxID) <span style="color: #ef4444;">*</span></label>
                        <input type="text" id="reviewTxHash" class="form-control tx-hash-input" placeholder="请输入区块链交易哈希">
                    </div>
                </div>

                <!-- 拒绝操作区 -->
                <div id="rejectSection" style="display: none;">
                    <div class="form-group">
                        <label>拒绝原因 <span style="color: #ef4444;">*</span></label>
                        <textarea id="reviewRejectReason" class="form-control" rows="3" placeholder="请输入拒绝原因"></textarea>
                    </div>
                </div>

                <!-- 操作类型切换 -->
                <div style="display: flex; gap: 20px; margin: 20px 0;">
                    <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
                        <input type="radio" name="reviewAction" value="approve" checked onclick="toggleReviewAction('approve')"> 通过
                    </label>
                    <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
                        <input type="radio" name="reviewAction" value="reject" onclick="toggleReviewAction('reject')"> 拒绝
                    </label>
                </div>

                <div class="form-group">
                    <label>管理员备注</label>
                    <textarea id="adminNote" class="form-control" rows="2" placeholder="可选备注"></textarea>
                </div>

                <div class="action-buttons">
                    <button class="btn-approve" onclick="submitReview()">确认提交</button>
                    <button class="btn-reject" onclick="closeReviewModal()">取消</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        let allWithdrawals = [];

        document.addEventListener('DOMContentLoaded', function() {
            loadWithdrawals();
            
            const statusFilter = document.getElementById('statusFilter');
            const searchInput = document.getElementById('searchInput');
            
            if (statusFilter) statusFilter.addEventListener('change', filterWithdrawals);
            if (searchInput) searchInput.addEventListener('input', filterWithdrawals);
            
            const closeModalBtn = document.getElementById('closeReviewModalBtn');
            if (closeModalBtn) closeModalBtn.addEventListener('click', closeReviewModal);
            
            const logoutBtn = document.getElementById('logoutBtn');
            if (logoutBtn) {
                logoutBtn.addEventListener('click', () => window.location.href = '/admin/index.html');
            }
            
            const adminNameSpan = document.getElementById('adminName');
            const storedAdmin = localStorage.getItem('admin_name');
            if (storedAdmin) {
                adminNameSpan.textContent = storedAdmin;
            }
            
            // 点击模态框背景关闭
            const modal = document.getElementById('reviewModal');
            if (modal) {
                modal.addEventListener('click', function(e) {
                    if (e.target === modal) closeReviewModal();
                });
            }
        });

        async function adminRequest(endpoint, options = {}) {
            options.credentials = 'include';
            options.headers = { 'Content-Type': 'application/json', ...options.headers };
            const res = await fetch(endpoint, options);
            return res.json();
        }

        async function loadWithdrawals() {
            const tbody = document.getElementById('withdrawalTableBody');
            if (tbody) tbody.innerHTML = '<tr><td colspan="10" class="loading"><i class="fas fa-spinner fa-pulse"></i> 加载中...</td></tr>';
            
            try {
                const stats = await adminRequest('/api/v1/admin/withdraw/stats');
                if (stats.success) {
                    const pendingCount = document.getElementById('pendingCount');
                    const approvedCount = document.getElementById('approvedCount');
                    const rejectedCount = document.getElementById('rejectedCount');
                    const pendingAmount = document.getElementById('pendingAmount');
                    
                    if (pendingCount) pendingCount.textContent = stats.data.pending_count || 0;
                    if (approvedCount) approvedCount.textContent = stats.data.approved_count || 0;
                    if (rejectedCount) rejectedCount.textContent = stats.data.rejected_count || 0;
                    if (pendingAmount) pendingAmount.textContent = (stats.data.pending_amount || 0).toFixed(2) + ' USDT';
                }

                const res = await adminRequest('/api/v1/admin/withdraw/all');
                if (res.success) {
                    allWithdrawals = res.data;
                    filterWithdrawals();
                }
            } catch (err) {
                if (tbody) tbody.innerHTML = '<tr><td colspan="10" class="loading" style="color: #ef4444;">加载失败，请刷新重试</td></tr>';
            }
        }

        function filterWithdrawals() {
            const status = document.getElementById('statusFilter')?.value || 'all';
            const search = document.getElementById('searchInput')?.value.toLowerCase() || '';
            
            let filtered = allWithdrawals;
            if (status !== 'all') {
                filtered = filtered.filter(w => w.status === status);
            }
            if (search) {
                filtered = filtered.filter(w => 
                    (w.username?.toLowerCase().includes(search) ||
                     w.uid?.toLowerCase().includes(search) ||
                     w.address?.toLowerCase().includes(search))
                );
            }
            renderTable(filtered);
        }

        function renderTable(list) {
            const tbody = document.getElementById('withdrawalTableBody');
            if (!tbody) return;
            
            if (list.length === 0) {
                tbody.innerHTML = '<tr><td colspan="10" class="loading">暂无记录</td></tr>';
                return;
            }

            let html = '';
            list.forEach(w => {
                const date = new Date(w.created_at).toLocaleString();
                const statusClass = w.status === 'pending' ? 'status-pending' : 
                                   w.status === 'approved' ? 'status-approved' : 'status-rejected';
                const statusText = w.status === 'pending' ? '待审核' : 
                                  w.status === 'approved' ? '已通过' : '已驳回';
                
                html += `
                    <tr>
                        <td>${w.id}</td>
                        <td>${date}</td>
                        <td>${w.username || w.user_id}<br><small style="color: #8e95a3;">UID: ${w.uid || '-'}</small></td>
                        <td>${w.amount} USDT</td>
                        <td>1 USDT</td>
                        <td>${(w.amount - 1).toFixed(2)} USDT</td>
                        <td>${w.network || '-'}</td>
                        <td><span class="address-truncate" title="${w.address || ''}">${w.address || '-'}</span></td>
                        <td><span class="status-badge ${statusClass}">${statusText}</span></td>
                        <td>
                            ${w.status === 'pending' ? 
                                `<button class="action-btn" onclick="openReviewModal(${w.id})"><i class="fas fa-gavel"></i> 审核</button>` : 
                                '<button class="action-btn" disabled style="opacity:0.5;"><i class="fas fa-check"></i> 已处理</button>'}
                        </td>
                    </tr>
                `;
            });
            tbody.innerHTML = html;
        }

        async function openReviewModal(id) {
            try {
                const res = await adminRequest(`/api/v1/admin/withdraw/detail/${id}`);
                if (res.success) {
                    const w = res.data;
                    document.getElementById('reviewId').value = w.id;
                    document.getElementById('reviewUser').textContent = `${w.username} (UID: ${w.uid})`;
                    document.getElementById('reviewAmount').textContent = w.amount + ' USDT';
                    document.getElementById('reviewNetAmount').textContent = (w.amount - 1) + ' USDT';
                    document.getElementById('reviewNetwork').textContent = w.network || '-';
                    document.getElementById('reviewAddress').textContent = w.address || '-';
                    document.getElementById('reviewBalance').textContent = w.user_balance + ' USDT';
                    
                    document.getElementById('reviewTxHash').value = '';
                    document.getElementById('reviewRejectReason').value = '';
                    document.getElementById('adminNote').value = '';
                    
                    document.getElementById('approveSection').style.display = 'block';
                    document.getElementById('rejectSection').style.display = 'none';
                    const approveRadio = document.querySelector('input[name="reviewAction"][value="approve"]');
                    if (approveRadio) approveRadio.checked = true;
                    
                    document.getElementById('reviewModal').classList.add('show');
                }
            } catch (err) {
                alert('获取详情失败');
            }
        }

        function closeReviewModal() {
            document.getElementById('reviewModal').classList.remove('show');
        }

        function toggleReviewAction(action) {
            document.getElementById('approveSection').style.display = action === 'approve' ? 'block' : 'none';
            document.getElementById('rejectSection').style.display = action === 'reject' ? 'block' : 'none';
        }

        async function submitReview() {
            const id = document.getElementById('reviewId').value;
            const action = document.querySelector('input[name="reviewAction"]:checked')?.value;
            const adminNote = document.getElementById('adminNote').value;
            
            if (action === 'approve') {
                const txHash = document.getElementById('reviewTxHash').value.trim();
                if (!txHash) {
                    alert('请输入交易哈希');
                    return;
                }
                
                try {
                    const res = await adminRequest(`/api/v1/admin/withdraw/${id}/approve`, {
                        method: 'POST',
                        body: JSON.stringify({ tx_hash: txHash, admin_note: adminNote })
                    });
                    
                    if (res.success) {
                        alert('提现已通过');
                        closeReviewModal();
                        loadWithdrawals();
                    } else {
                        alert(res.message || '操作失败');
                    }
                } catch (err) {
                    alert('操作失败');
                }
            } else if (action === 'reject') {
                const reason = document.getElementById('reviewRejectReason').value.trim();
                if (!reason) {
                    alert('请输入拒绝原因');
                    return;
                }
                
                try {
                    const res = await adminRequest(`/api/v1/admin/withdraw/${id}/reject`, {
                        method: 'POST',
                        body: JSON.stringify({ admin_note: reason + (adminNote ? ` (${adminNote})` : '') })
                    });
                    
                    if (res.success) {
                        alert('提现已拒绝');
                        closeReviewModal();
                        loadWithdrawals();
                    } else {
                        alert(res.message || '操作失败');
                    }
                } catch (err) {
                    alert('操作失败');
                }
            }
        }
    </script>
</body>
</html>